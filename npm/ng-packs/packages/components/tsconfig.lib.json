{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": [],

    // Tutarlı ES2022
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "dom"],           // ✅ Düzeltildi

    // Angular için
    "moduleResolution": "bundler",
    "useDefineForClassFields": false,
  },
  "exclude": [
    "src/test-setup.ts",
    "src/**/*.spec.ts",                 // ✅ src/ prefix ekledim
    "jest.config.ts"
  ],
  "include": ["src/**/*.ts"]            // ✅ Düzeltildi
}
